# 레시피 깃허브: 환경 변수 설정
# 1. Supabase 접속 정보 (Supabase Dashboard > Settings > API에서 확인 가능)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# 2. Cloudflare R2 접속 정보
VITE_R2_WORKER_URL=your_r2_worker_url
VITE_R2_PUBLIC_DOMAIN=your_r2_public_domain_url

# 3. Google Gemini API 키 (https://aistudio.google.com/app/apikey 에서 발급)
VITE_GEMINI_API_KEY=your_actual_api_key_here
